<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="car_model">
  <xacro:property name="pkg_name" value="car_model"/>
  <xacro:property name="path_prefix" value="file:///home/jessie/project_ws/src/${pkg_name}"/>
  <xacro:property name="shoulder_tilt" value="1.2"/>
  <xacro:property name="elbow_tilt" value="0"/>

  <!-- 惯性宏 -->
  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001" />
    </inertial>
  </xacro:macro>
 
  <!-- 基础底座 -->
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.135" rpy="0 0 3.14159"/>
  </joint>
 
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 -0.05" rpy="0 0 0" />
      <mass value="100.0" />
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.01" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${path_prefix}/meshes/base_link.STL" /></geometry>
      <material name=""><color rgba="0 0 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0" />
      <geometry><box size="0.25 0.2 0.1" /></geometry>
    </collision>
    <!-- 支撑轮摩擦力设为0 -->
    <collision name="left_front_caster">
      <origin xyz="0.18 0.12 -0.08" rpy="0 0 0" />
      <geometry><sphere radius="0.038" /></geometry>
      <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
    </collision>
    <collision name="right_front_caster">
      <origin xyz="0.18 -0.12 -0.08" rpy="0 0 0" />
      <geometry><sphere radius="0.038" /></geometry>
      <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
    </collision>
    <collision name="left_rear_caster">
      <origin xyz="-0.18 0.12 -0.08" rpy="0 0 0" />
      <geometry><sphere radius="0.04" /></geometry>
      <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
    </collision>
    <collision name="right_rear_caster">
      <origin xyz="-0.18 -0.12 -0.08" rpy="0 0 0" />
      <geometry><sphere radius="0.04" /></geometry>
      <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
    </collision>
  </link>

  <!-- 机械臂关节 1 -->
  <link name="link1">
    <xacro:box_inertial mass="0.01" x="0.05" y="0.05" z="0.05" />
    <visual><geometry><mesh filename="${path_prefix}/meshes/link1.STL" /></geometry><material name=""><color rgba="0.7 0.7 0.7 1" /></material></visual>
    <collision><geometry><mesh filename="${path_prefix}/meshes/link1.STL" /></geometry></collision>
  </link>
  <joint name="joint1" type="revolute">
    <origin xyz="0 0 0.03" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="link1" />
    <axis xyz="0 0 -1" />
    <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0" />
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <!-- 机械臂关节 2 -->
  <link name="link2">
    <xacro:box_inertial mass="0.01" x="0.05" y="0.05" z="0.05" />
    <visual><geometry><mesh filename="${path_prefix}/meshes/link2.STL" /></geometry><material name=""><color rgba="0.7 0.7 0.7 1" /></material></visual>
    <collision><geometry><mesh filename="${path_prefix}/meshes/link2.STL" /></geometry></collision>
  </link>
  <joint name="joint2" type="revolute">
    <origin xyz="-0.0046 -0.0296 0.16" rpy="1.5708 ${shoulder_tilt} 0" />
    <parent link="link1" />
    <child link="link2" />
    <axis xyz="0.1537 0 -0.9881" />
    <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0" />
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <!-- 机械臂关节 3 -->
  <link name="link3">
    <xacro:box_inertial mass="0.01" x="0.05" y="0.05" z="0.05" />
    <visual><geometry><mesh filename="${path_prefix}/meshes/link3.STL" /></geometry><material name=""><color rgba="0.7 0.7 0.7 1" /></material></visual>
    <collision><geometry><mesh filename="${path_prefix}/meshes/link3.STL" /></geometry></collision>
  </link>
  <joint name="joint3" type="revolute">
    <origin xyz="-0.2074 -0.0052 -0.0322" rpy="0 ${elbow_tilt} 0" />
    <parent link="link2" />
    <child link="link3" />
    <axis xyz="-0.1537 0 0.9881" />
    <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0" />
    <dynamics damping="1.0" friction="1.0"/>
  </joint>

  <!-- 吸盘物理连接点 grasp_link -->
  <link name="grasp_link">
    <inertial>
      <mass value="0.05" />
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
    <collision><geometry><sphere radius="0.0001"/></geometry></collision>
  </link>

  <joint name="grasp_joint" type="fixed">
    <parent link="link3" />
    <child link="grasp_link" />
    <origin xyz="-0.02 -0.25 -0.03" rpy="0 0 0" /> 
  </joint>

  <!-- 防止 grasp_link 在 Gazebo 中被优化掉（关键修复） -->
  <gazebo reference="grasp_joint">
    <disableFixedJointLumping>true</disableFixedJointLumping>
  </gazebo>
    
  <!-- 夹爪 paw1 -->
  <link name="paw1">
    <xacro:box_inertial mass="0.01" x="0.05" y="0.05" z="0.05" />
    <visual><geometry><mesh filename="${path_prefix}/meshes/paw1.STL" /></geometry><material name=""><color rgba="0.7 0.7 0.7 1" /></material></visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.18 0.15 0.057"/></geometry>
      <surface>
        <friction><ode><mu>100.0</mu><mu2>100.0</mu2></ode></friction>
        <contact><ode><kp>1000000.0</kp><kd>1.0</kd><min_depth>0.001</min_depth></ode></contact>
      </surface>
    </collision>
  </link>
  <joint name="paw1_joint" type="prismatic">
    <origin xyz="-0.0147 -0.2336 -0.0680" rpy="0 0 0" />
    <parent link="link3" />
    <child link="paw1" />
    <axis xyz="-0.1537 0 0.9881" />
    <limit lower="-0.040" upper="0.040" effort="50" velocity="0.1" />
    <dynamics damping="10.0" friction="5.0"/> 
  </joint>

  <!-- 夹爪 paw2 -->
  <link name="paw2">
    <xacro:box_inertial mass="0.01" x="0.05" y="0.05" z="0.05" />
    <visual><geometry><mesh filename="${path_prefix}/meshes/paw2.STL" /></geometry><material name=""><color rgba="0.7 0.7 0.7 1" /></material></visual>
    <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.18 0.15 0.057"/></geometry>
      <surface>
        <friction><ode><mu>100.0</mu><mu2>100.0</mu2></ode></friction>
        <contact><ode><kp>1000000.0</kp><kd>1.0</kd><min_depth>0.001</min_depth></ode></contact>
      </surface>
    </collision>
  </link>
  <joint name="paw2_joint" type="prismatic">
    <origin xyz="-0.0270 -0.2336 0.0109" rpy="3.1416 0 0" />
    <parent link="link3" />
    <child link="paw2" />
    <axis xyz="-0.1537 0 -0.9881" />
    <limit lower="-0.040" upper="0.040" effort="50" velocity="0.1" />
    <dynamics damping="10.0" friction="5.0"/> 
  </joint>

  <!-- 轮子部分 -->
  <link name="wheel1">
    <inertial><origin xyz="0 0 0" rpy="0 0 0" /><mass value="0.5" /><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" /></inertial>
    <visual><geometry><mesh filename="${path_prefix}/meshes/wheel1.STL" /></geometry><material name=""><color rgba="0.2 0.2 0.2 1" /></material></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0" /><geometry><cylinder radius="0.04" length="0.02"/></geometry></collision>
  </link>
  <joint name="wheel1_joint" type="continuous">
    <origin xyz="0.060547 -0.11215 -0.08" rpy="1.5708 0 -3.1416" /><parent link="base_link" /><child link="wheel1" /><axis xyz="0 0 -1" />
  </joint>
  <link name="wheel2">
    <inertial><origin xyz="0 0 0" rpy="0 0 0" /><mass value="0.5" /><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" /></inertial>
    <visual><geometry><mesh filename="${path_prefix}/meshes/wheel2.STL" /></geometry><material name=""><color rgba="0.2 0.2 0.2 1" /></material></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0" /><geometry><cylinder radius="0.04" length="0.02"/></geometry></collision>
  </link>
  <joint name="wheel2_joint" type="continuous">
    <origin xyz="0.060547 0.11785 -0.08" rpy="1.5708 0 0" /><parent link="base_link" /><child link="wheel2" /><axis xyz="0 0 1" />
  </joint>

  <!-- 传感器 -->
  <link name="camera"><xacro:box_inertial mass="0.01" x="0.05" y="0.05" z="0.05" /><visual><geometry><mesh filename="${path_prefix}/meshes/camera.STL" /></geometry></visual><collision><geometry><mesh filename="${path_prefix}/meshes/camera.STL" /></geometry></collision></link>
  <joint name="camera_joint" type="fixed"><origin xyz="-0.10 0.012 -0.10" rpy="0 0 3.14159" /><parent link="base_link" /><child link="camera" /></joint>
  <link name="radar"><xacro:box_inertial mass="0.01" x="0.05" y="0.05" z="0.05" /><visual><geometry><mesh filename="${path_prefix}/meshes/radar.STL" /></geometry></visual><collision><geometry><mesh filename="${path_prefix}/meshes/radar.STL" /></geometry></collision></link>
  <joint name="radar_joint" type="fixed"><origin xyz="0 0 0" rpy="0 0 0" /><parent link="base_link" /><child link="radar" /></joint>

  <!-- 控制器配置 -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware><plugin>gazebo_ros2_control/GazeboSystem</plugin></hardware>
    <joint name="joint1"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint2"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="joint3"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="paw1_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="paw2_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="wheel1_joint"><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="wheel2_joint"><state_interface name="position"/><state_interface name="velocity"/></joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find car_model)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros><namespace>/</namespace></ros>
      <left_joint>wheel1_joint</left_joint><right_joint>wheel2_joint</right_joint>
      <wheel_separation>0.23</wheel_separation><wheel_diameter>0.08</wheel_diameter>
      <max_wheel_torque>600</max_wheel_torque><max_wheel_acceleration>8.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom><publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame><robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  
  <gazebo reference="radar">
    <sensor name="lidar" type="ray">
      <always_on>true</always_on><visualize>true</visualize><update_rate>10</update_rate>
      <ray>
        <scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14</min_angle><max_angle>3.14</max_angle></horizontal></scan>
        <range><min>0.3</min><max>10.0</max><resolution>0.015</resolution></range>
      </ray>
      <plugin name="scan" filename="libgazebo_ros_ray_sensor.so">
        <ros><remapping>~/out:=scan</remapping></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>radar</frame_name>
      </plugin>
    </sensor>
  </gazebo>
 
  <gazebo reference="camera">
    <sensor type="camera" name="camera_sensor">
      <update_rate>30.0</update_rate><always_on>true</always_on><visualize>true</visualize>
      <camera name="head">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.02</near><far>300</far></clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <cameraName>camera</cameraName><frameName>camera</frameName>
      </plugin>
    </sensor>
  </gazebo>
 
  <!-- 真空吸盘插件配置 -->
  <gazebo>
    <plugin name="vacuum_gripper" filename="libgazebo_ros_vacuum_gripper.so">
      <ros>
        <namespace>/gripper</namespace>
      </ros>
      <link_name>grasp_link</link_name>
      <max_distance>0.15</max_distance>
      <max_force>10000</max_force>
      <fixed>true</fixed>
    </plugin>
  </gazebo>
  <gazebo reference="paw1">
  <turnGravityOff>true</turnGravityOff>
  <material>Gazebo/Grey</material>
</gazebo>

<gazebo reference="paw2">
  <turnGravityOff>true</turnGravityOff>
  <material>Gazebo/Grey</material>
</gazebo>
  <gazebo reference="link1"><turnGravityOff>true</turnGravityOff><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="link2"><turnGravityOff>true</turnGravityOff><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="link3"><turnGravityOff>true</turnGravityOff><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="paw1"><turnGravityOff>true</turnGravityOff><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="paw2"><turnGravityOff>true</turnGravityOff><material>Gazebo/Grey</material></gazebo>
  <gazebo reference="base_link"><material>Gazebo/Blue</material></gazebo>
  <gazebo reference="wheel1"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="wheel2"><material>Gazebo/Black</material></gazebo>
  <gazebo reference="grasp_link"><material>Gazebo/Red</material></gazebo>
</robot>
